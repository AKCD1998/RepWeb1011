# Profile: render-live
# In shared deployed environments, prefer RX1011_* names so this service does
# not collide with another app's DATABASE_URL, JWT_SECRET, or CORS_ORIGIN.
# For local dev/testing, use the local-simulation profile in server/.env.local-simulation instead of editing this file.
RX1011_DATABASE_URL=
PORT=5050
RX1011_CORS_ORIGIN=http://localhost:5173,https://your-frontend-host.example
RX1011_JWT_SECRET=change-me
RX1011_PATIENTS_CSV_PATH=
