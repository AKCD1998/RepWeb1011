{
  "name": "rx1011-react",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:full": "concurrently -k \"npm run server\" \"npm run dev\"",
    "dev:local-sim": "node scripts/dev-mock.mjs",
    "dev:mock": "npm run dev:local-sim",
    "server": "node server/index.js",
    "start": "node server/index.js",
    "db:local-sim:init": "node scripts/db-local-init.mjs",
    "db:local-sim:migrate": "node scripts/db-local-migrate.mjs",
    "db:local-sim:seed": "node scripts/db-local-seed.mjs",
    "db:local-sim:bootstrap": "npm run db:local-sim:init && npm run db:local-sim:migrate && npm run db:local-sim:seed",
    "db:local:init": "npm run db:local-sim:init",
    "db:local:migrate": "npm run db:local-sim:migrate",
    "db:local:seed": "npm run db:local-sim:seed",
    "db:local:bootstrap": "npm run db:local-sim:bootstrap",
    "db:migration:status": "node scripts/db-migration-status.mjs",
    "db:migration:apply": "node scripts/db-migration-apply.mjs",
    "db:prod:status:0022": "node scripts/db-migration-status.mjs --profile production-live --migration 0022_incident_report_resolution_actions.sql",
    "db:prod:apply:0022": "node scripts/db-migration-apply.mjs --profile production-live --migration 0022_incident_report_resolution_actions.sql",
    "db:schema:diff": "node scripts/db-schema-diff.mjs",
    "db:schema:diff:render-vs-localsim": "node scripts/db-schema-diff.mjs --left production-live --right local-sim",
    "audit:lot-whitelists": "node scripts/audit-lot-whitelists.mjs",
    "audit:receiving-search": "node scripts/audit-receiving-search-gaps.mjs",
    "audit:unit-levels": "node scripts/audit-unit-levels.mjs",
    "verify:unit-level": "node scripts/verify-unit-level-stability.mjs",
    "check:server": "node scripts/check-server-syntax.mjs",
    "ci": "npm run check:server && npm run build",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "axios": "^1.13.5",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "csv-parse": "^5.6.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.3",
    "mqtt": "^5.15.1",
    "pg": "^8.18.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^5.5.0",
    "react-router-dom": "^6.30.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^9.0.1",
    "vite": "^7.3.1"
  }
}
